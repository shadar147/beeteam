# Postgres
DATABASE_URL=postgres://beeteam:beeteam@localhost:5432/beeteam
# Test DB (ephemeral, tmpfs, port 5433) — used by api/scripts/test.sh
TEST_DATABASE_URL=postgres://beeteam:beeteam@localhost:5433/beeteam

# Auth (used by later plans)
JWT_SECRET=dev-only-change-me

# MinIO / S3 (used by the Files slice)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=beeteam
S3_ACCESS_KEY=beeteam
S3_SECRET_KEY=beeteam-secret

# API
API_BIND=0.0.0.0:8080
WEB_ORIGIN=http://localhost:3000
